  /* Glow + Float */
  .hero-img-glow {
    position: relative; display: inline-flex;
    align-items: center; justify-content: center;
    animation: float 5s ease-in-out infinite;
  }
  .hero-img-glow::before {
    content: ''; position: absolute; inset: -30px; border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(19,0,202,0.28) 0%, rgba(19,0,202,0.08) 50%, transparent 75%);
    animation: glow-pulse 3s ease-in-out infinite; z-index: 0;
  }
  .hero-img-glow::after {
    content: ''; position: absolute; inset: -2px; border-radius: 28px;
    background: linear-gradient(135deg, rgba(19,0,202,0.95) 0%, transparent 40%, transparent 60%, rgba(19,0,202,0.6) 100%);
    z-index: 1; animation: border-fade 4s linear infinite;
  }
  .hero-img-inner {
    position: relative; z-index: 2; border-radius: 26px; overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(19,0,202,0.5),
      0 0 40px rgba(19,0,202,0.3),
      0 0 80px rgba(19,0,202,0.12),
      0 30px 60px rgba(0,0,0,0.6);
  }
  .hero-img-inner img { width: 100%; max-width: 460px; height: auto; display: block; }

  .corner { position: absolute; width: 20px; height: 20px; z-index: 3; }
  .corner-tl { top: -4px; left: -4px; border-top: 2px solid #1300ca; border-left: 2px solid #1300ca; border-radius: 4px 0 0 0; }
  .corner-tr { top: -4px; right: -4px; border-top: 2px solid #1300ca; border-right: 2px solid #1300ca; border-radius: 0 4px 0 0; }
  .corner-bl { bottom: -4px; left: -4px; border-bottom: 2px solid #1300ca; border-left: 2px solid #1300ca; border-radius: 0 0 0 4px; }
  .corner-br { bottom: -4px; right: -4px; border-bottom: 2px solid #1300ca; border-right: 2px solid #1300ca; border-radius: 0 0 4px 0; }

  @keyframes float { 0%,100% { transform: translateY(0px); } 50% { transform: translateY(-12px); } }
  @keyframes glow-pulse { 0%,100% { opacity: 0.7; transform: scale(1); } 50% { opacity: 1; transform: scale(1.05); } }
  @keyframes border-fade { 0%,100% { opacity: 0.9; } 50% { opacity: 0.35; } }

  /* HERO RIGHT */
