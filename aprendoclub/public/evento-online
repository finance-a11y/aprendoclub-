  .footer-social a:hover { border-color: var(--verde); color: var(--verde); }
  .footer-col h4 { font-size: 0.75rem; font-weight: 800; color: var(--blanco); margin-bottom: 16px; text-transform: uppercase; letter-spacing: 2px; }
  .footer-col a { display: block; font-size: 0.8rem; color: var(--texto-muted); text-decoration: none; margin-bottom: 10px; transition: color 0.2s; font-weight: 500; }
  .footer-col a:hover { color: var(--verde); }
  .footer-bottom { border-top: 1px solid var(--gris-borde); padding: 20px 40px; display: flex; justify-content: space-between; align-items: center; max-width: 1100px; margin: 0 auto; font-size: 0.76rem; color: var(--texto-muted); font-weight: 500; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
